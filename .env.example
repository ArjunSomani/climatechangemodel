# Override the engine's default data directory (engine/data/), e.g. to
# point at a volume populated by the EIA ingestion pipeline instead of
# the hand-copied CSVs used for local dev.
ENGINE_DATA_DIR=

# Reserved for the scheduled EIA ingestion job (PRD §9) -- not read by
# anything yet in Phase 0. Never commit a real key.
EIA_API_KEY=
