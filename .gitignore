# Full pristine clone of cliffgold/Optimize, kept locally as reference
# material only (has its own .git; never nest it into this repo's history).
vendor/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/

# Raw EIA hourly CSVs -- bulky, regenerable from vendor/ (see
# engine/scripts/convert_eia_to_parquet.py) or refresh_eia_data.py.
# The derived eia_parquet/ store IS committed (unlike this), since
# run_worker.py's Render deploy needs it at runtime and
# refresh_eia_data.py is incremental-only (can't bootstrap from an
# empty checkout) -- see engine/data/eia_parquet/meta.json for the
# version it was generated under.
engine/data/eia_hourly/

# Env / secrets
.env
.env.local

# OS cruft
.DS_Store

# Claude Code local session state
.claude/
