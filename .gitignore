# Full pristine clone of cliffgold/Optimize, kept locally as reference
# material only (has its own .git; never nest it into this repo's history).
vendor/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/

# engine/data/eia_hourly/ and eia_parquet/ used to be gitignored as
# "bulky, regenerable" -- but core.py's get_eia_data() reads eia_hourly/
# CSVs directly at runtime (eia_parquet/ is only a derived aggregate for
# the Data Explorer frontend + version-stamping), and refresh_eia_data.py
# is incremental-only (can't bootstrap either from an empty checkout).
# The custom-run worker (run_worker.py, run via GitHub Actions) needs
# eia_hourly/ present in a fresh checkout, so both are now committed.
# See engine/data/eia_parquet/meta.json for the version they were
# generated under.

# Env / secrets
.env
.env.local

# OS cruft
.DS_Store

# Claude Code local session state
.claude/
